# Use official Node.js 18 image
FROM node:18-alpine

# Set working directory
WORKDIR /app

# Copy only package manifests first and install production deps
COPY package.json package-lock.json ./
RUN npm install --omit=dev

# Copy all source (including your pre-built extension in extensions/.../dist)
COPY . .

# Set production mode
ENV NODE_ENV=production

# Expose the port your Koa server listens on
EXPOSE 8081

# Start the application
CMD ["npm", "start"]
