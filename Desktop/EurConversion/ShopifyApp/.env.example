# Your Shopify app credentials
SHOPIFY_API_KEY=your_api_key
SHOPIFY_API_SECRET=your_api_secret

# What your app needs to read/write
SCOPES=write_checkouts,read_orders

# Your shop domain
SHOP=your-shop-name.myshopify.com

# Public URL after you deploy (Railway)
HOST=https://<YOUR_RAILWAY_SUBDOMAIN>.up.railway.app

# Port (Railway will override with its own $PORT)
PORT=3000
NODE_ENV=development
